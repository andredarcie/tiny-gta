# --- Upstash Redis (crie um banco grátis em https://upstash.com) ---
# Pegue estes dois valores na aba "REST API" do seu database Upstash.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# --- CORS: origens permitidas (separadas por vírgula). Só o esquema://host conta. ---
# html-classic.itch.zone é a origem REAL do jogo HTML5 no itch (iframe).
ALLOWED_ORIGINS=https://andredarcie.github.io,https://andredarcie.itch.io,https://html-classic.itch.zone

# --- Anti-cheat / plausibilidade (opcionais; já têm padrão no código) ---
BASE_MONEY=250          # dinheiro inicial da partida
MONEY_PER_SEC=200       # teto de ganho por segundo de partida
MONEY_HARD_CAP=10000000 # teto absoluto
SESSION_TTL=14400       # validade do token de sessão (s) = 4h
MIN_RUN_SECONDS=20      # partida mais curta que isso é rejeitada
RL_MAX=30               # nº máx. de envios por janela, por IP
RL_WINDOW=600           # janela do rate-limit (s) = 10 min

# --- Ranking por mini game (/api/minigame; opcionais, já têm padrão no código) ---
MG_SCORE_CAP=1000000    # teto do score de UMA sessão de mini game
MG_PRIOR_N=5            # partidas "fantasma" do Bayes (suaviza pouca amostra)
MG_PRIOR_RATE=0.35      # taxa de vitória a priori (puxa iniciante pra baixo)
MG_VOLUME_W=0.5         # peso do bônus de volume (log2) no rating

# --- Bloodstains: multiplayer assíncrono das poças de morte (/api/bloodstains) ---
BLOODSTAIN_TTL=21600    # validade de uma poça (s) = 6h
BLOODSTAIN_MAX=2000000  # teto do dinheiro de UMA poça (clampa criação + coleta)
BLOODSTAIN_KEEP=300     # quantas poças (as mais novas) o índice mantém
BLOODSTAIN_RETURN=120   # máximo de poças devolvidas no GET
BLOODSTAIN_COORD=5000   # limite de coordenada aceito na criação (anti-forja)
