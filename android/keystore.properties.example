# Release signing for Google Play.
#
# Copy this file to  android/keystore.properties  and fill in the real values.
# keystore.properties and the .jks file are git-ignored — NEVER commit them, and
# keep a backup of the .jks + passwords: losing them means you can't update the app.
#
# Generate the keystore once (needs the JDK's keytool, ships with the JDK):
#
#   cd android
#   keytool -genkey -v -keystore tinygta-release-key.jks -alias tinygta \
#           -keyalg RSA -keysize 2048 -validity 10000
#
# Then build a signed Play bundle:  ./gradlew bundleRelease
# (output: android/app/build/outputs/bundle/release/app-release.aab)

# Path to the keystore, resolved relative to the android/ folder.
storeFile=tinygta-release-key.jks
storePassword=CHANGE_ME
keyAlias=tinygta
keyPassword=CHANGE_ME
